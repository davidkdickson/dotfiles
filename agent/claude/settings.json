{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(git:*)",
      "Bash(gh *)",
      "Bash(bun *)",
      "Bash(npm *)",
      "Bash(docker exec:*)",
      "Bash(command *)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "sentry@claude-plugins-official": true,
    "apple-notes@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true
}
