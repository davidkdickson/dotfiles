{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(git:*)",
      "Bash(gh *)",
      "Bash(bun *)",
      "Bash(npm *)",
      "Bash(docker exec:*)",
      "Bash(command *)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep"
    ]
  },
  "extraKnownMarketplaces": {
    "apple-notes-marketplace": {
      "source": {
        "source": "github",
        "repo": "peerasak-u/apple-notes-skill"
      }
    }
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff"
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "enabledPlugins": {
    "apple-notes@apple-notes-marketplace": true
  }
}
